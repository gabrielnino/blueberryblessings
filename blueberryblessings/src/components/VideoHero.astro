---
import { Image } from "astro:assets";
import Logo from "./Logo.astro";
import blueberryBasket from "../assets/blueberry_basket.jpg";

const YOUTUBE_VIDEO_ID = "civWjg2_Ww4";
---

<div id="home" class="relative w-full min-h-screen flex flex-col justify-between bg-brand-blue-deep text-white">
  
  {/* 1. Video Background Layer (z-0) */}
  <div class="absolute inset-0 w-full h-full overflow-hidden pointer-events-none z-0">
    {/* Fallback Background (Deep Blue) */}
    <div class="absolute inset-0 bg-brand-blue-deep"></div>
    
    {/* YouTube Video iframe Embed Placeholder (Loaded dynamically on desktop for performance) */}
    <div 
      id="youtube-hero-container" 
      class="absolute inset-0 w-full h-full opacity-0 transition-opacity duration-1000 ease-out pointer-events-none"
    ></div>
  </div>

  {/* 2. Dark Overlay (z-10) */}
  <div class="absolute inset-0 bg-gradient-to-b from-brand-blue-deep/90 via-brand-blue-deep/70 to-brand-blue-deep/80 z-10 pointer-events-none"></div>

  {/* 3. Top Header/Navigation (z-20) */}
  <header class="relative z-20 w-full flex flex-col items-center pt-6 pb-2 px-6">
    {/* Centered Logo */}
    <div class="flex items-center justify-center mb-2 transition-transform duration-300 hover:scale-105">
      <Logo class="w-16 h-16" />
    </div>
    {/* Centered Navigation Links */}
    <nav class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-xs md:text-sm font-serif tracking-[0.25em] text-brand-gold uppercase">
      <a href="#home" class="hover:text-white transition-colors duration-200">Home</a>
      <a href="#about" class="hover:text-white transition-colors duration-200">About</a>
      <a href="#shop" class="hover:text-white transition-colors duration-200">Shop</a>
      <a href="#recipes" class="hover:text-white transition-colors duration-200">Recipes</a>
      <a href="#contact" class="hover:text-white transition-colors duration-200">Contact</a>
    </nav>
  </header>

  {/* 4. Two-Column Hero Content Container (z-20) */}
  <div class="relative z-20 max-w-6xl mx-auto px-6 md:px-12 py-6 md:py-10 flex-1 grid grid-cols-1 md:grid-cols-2 gap-8 items-center w-full">
    
    {/* Left Column: Copy & Call to Action */}
    <div class="flex flex-col items-center md:items-start text-center md:text-left animate-fade-in-up">
      {/* Main Title */}
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-medium tracking-wide leading-[1.15] text-white">
        Welcome to <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-gold via-yellow-200 to-brand-gold">
          Blueberry Blessings!
        </span>
      </h1>

      {/* Subtitle */}
      <p class="mt-4 max-w-md text-sm sm:text-base md:text-lg text-slate-200/90 font-light leading-relaxed">
        Discover the taste of nature's blessing.
      </p>

      {/* Golden Action Button */}
      <div class="mt-6 w-full sm:w-auto">
        <a
          href="#shop"
          class="inline-block w-full sm:w-auto px-8 py-3 bg-brand-gold hover:bg-brand-gold-hover text-white uppercase text-xs font-semibold tracking-wider rounded-md text-center transition-all duration-300 shadow-md shadow-brand-gold/10 hover:shadow-brand-gold/20 transform hover:-translate-y-[1px]"
        >
          Shop Now
        </a>
      </div>
    </div>

    {/* Right Column: Featured Image of Blueberry Basket */}
    <div class="flex items-center justify-center animate-fade-in-up animation-delay-200">
      <div class="relative w-full max-w-[280px] sm:max-w-xs md:max-w-sm lg:max-w-md aspect-square rounded-2xl overflow-hidden border-4 border-brand-gold/40 shadow-2xl shadow-brand-blue-deep/60 group">
        <Image
          src={blueberryBasket}
          alt="Fresh Blueberry Basket in Orchard at Blueberry Blessings farm"
          width={800}
          height={800}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        {/* Soft inner gold glow hover effect */}
        <div class="absolute inset-0 bg-brand-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>
    </div>

  </div>

  {/* Subtle Bottom Wave/Blend Gradient */}
  <div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-brand-blue-deep to-transparent pointer-events-none z-10"></div>
</div>

<script>
  const YOUTUBE_VIDEO_ID = "civWjg2_Ww4";
  
  // Check if we are on desktop (width >= 1024px) to defer loading and save bandwidth on mobile
  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
  const container = document.getElementById('youtube-hero-container');

  if (isDesktop && container) {
    const iframe = document.createElement('iframe');
    iframe.id = "hero-video-iframe";
    iframe.src = `https://www.youtube-nocookie.com/embed/${YOUTUBE_VIDEO_ID}?autoplay=1&mute=1&loop=1&playlist=${YOUTUBE_VIDEO_ID}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1`;
    iframe.title = "Blueberry Fields Background Video";
    iframe.allow = "autoplay; encrypted-media";
    iframe.className = "absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-screen h-[56.25vw] min-h-screen min-w-[177.77vh] border-0";
    iframe.style.pointerEvents = "none";
    
    // Smooth transition
    iframe.addEventListener('load', () => {
      container.classList.remove('opacity-0');
      container.classList.add('opacity-35');
    });

    container.appendChild(iframe);

    // Fallback load transition
    setTimeout(() => {
      container.classList.remove('opacity-0');
      container.classList.add('opacity-35');
    }, 2000);
  }
</script>
